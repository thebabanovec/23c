basic.show_string(txt)\r\n\r\n\r\n\r\ndef displejOdpovedi(oznacenaOdpoved): #predelat na OLED\r\n    basic.clear_screen()\r\n    for i in range(4):\r\n        if odpovedi[level][scena][i] == None:\r\n            basic.show_string(\"-----------\")\r\n        elif i == oznacenaOdpoved:\r\n            basic.show_string(\"0.\" + odpovedi[level][scena][i])\r\n        else: \r\n            basic.show_string(i+1 + \".\" + odpovedi[level][scena][i])\r\n\r\ndef answerTime():\r\n    navigation = 0\r\n    while not(buttonIsPressed(confirmButton) and\r\n      odpovedi[level][scena][navigation - 1] != None):\r\n        \r\n        if navigation == 0:\r\n            displejTextu(0,None)\r\n        else:\r\n            displejOdpovedi(navigation - 1)\r\n      \r\n        basic.pause(200)\r\n        if buttonIsPressed(downButton) and navigation < 5:\r\n            navigation = navigation + 1\r\n        elif buttonIsPressed(upButton) and navigation > 0:\r\n            navigation = navigation - 1\r\n        \r\n\r\n    return navigation - 1\r\n\r\n# Plany: funkce čekání na potvzení(ukáže text a čeká než ho hráč odsouhlasí)\r\n#        funkce level executionn(celá logika jednoho levlu v jedné funkci) vrátí True pokud uspjeje hrac a False když ne\r\n#        level loop = while True loop, který se breakne pokud hrac uspjeje level\r\n#        více stránkové odpovědi = hledá kolik odpovědí se vejde do limitu(musim jeste zjistit) a podle toho rozprozstře odpovědi","pxt.json":"{\n    \"name\": \"23C\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"tinkercademy-tinker-kit\": \"github:tinkertanker/pxt-tinkercademy-tinker-kit#v1.1.1\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}},{"timestamp":1774635955242,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"></block><block type=\"device_forever\" x=\"225\" y=\"20\"></block></xml>","main.ts":"","README.md":"","main.py":"level = 0\r\nscena = 0\r\n\r\nnavigation = 0\r\nbuttons = AnalogPin.P0\r\nupButton = ADKeys.A\r\ndownButton = ADKeys.E\r\nconfirmButton = ADKeys.C\r\n\r\ncomeon = \"Smysl hry je zabit Caesara, tudiz odmitnout jeho vrazdu postrada smysl. Zkus to znovu. \"\r\ntexty = [ #prvni text v scene je ten ktery se objevi pri otazkach\r\n    #level 1\r\n    [[\"Bibulus:  Zdravim priteli! Mam skvele zpravy - od dnesniho dne jsem konzulem! Jen se obavam, že comita centuriata nezvolila jen moudre. Caesar je konzulem, to nemuzeme dopustit! Vem si tento elixir, at se nahodou objevi v jeho poharu.\",\r\n    \"Bibulus:  Oddanost jsi mi neprisahal pro nic za nic! Seber se a bez, nebo budes dalsi.\"\r\n    ], #scena 1\r\n    [\"Nemam cas, ani naladu na tve zertíky. Udelas to, nebo ne?\"\r\n    ], #scena 1.5\r\n    [\"\"],],\r\n    [[\"\"],\r\n    [\"\"],\r\n    [\"\"],],\r\n]\r\nodpovedi = [\r\n        #level 0\r\n    [[\"Cokoliv si prejete, pane Bibule. (vezmes si lahvicku)\",\r\n    \"Uhm… Pane, jste si jisty. To, o čem mluvite neni nic lehkovazného, je to VRAZDA!\",\r\n    \"NIKDY! Ja slouzim Caesarovi a nikdy bych mu neublizil!\",\r\n    \"Kdoze jste? V zivotě jsem vas nevidel…\"\r\n    ], #scena 1\r\n    [\" Omlouvam se, pane, hned to provedu.\",\r\n    \" Ne. Nebudu zabijet pro ciziho cloveka.\"],  #scena 1.5\r\n    [\"A02\",\"B02\",\"C02\",\"D02\"]], #scena 2\r\n        #level 1\r\n    [[\"A10\",\"B10\",\"C10\",\"D10\"], # scena 0\r\n    [\"A11\",\"B11\",\"C11\",\"D11\"],  #scena 1 \r\n    [\"A12\",\"B12\",\"C12\",\"D12\"]], #scena 2\r\n] \r\nOLED.init(128, 64)\r\n\r\ndisplejOdpovedi(3)\r\n\r\ndef buttonPressed(button):\r\n    if pins.analog_read_pin(buttons) ==  button:\r\n        return True\r\n    else:\r\n        return False\r\n\r\ndef displejTextu(txtNumero, txt ): #predelat na OLED\r\n    basic.clear_screen()\r\n    if txt == None: #mega genialni system jak mit hledani z listu i specialni texty v jednom\r\n        basic.show_string(texty[level][scena][txtNumero])\r\n    else:\r\n        basic.show_string(txt)\r\n\r\n\r\n\r\ndef displejOdpovedi(oznacenaOdpoved): #predelat na OLED\r\n    basic.clear_screen()\r\n    for i in range(4):\r\n        if odpovedi[level][scena][i] == None:\r\n            basic.show_string(\"-----------\")\r\n        elif i == oznacenaOdpoved:\r\n            basic.show_string(\"0.\" + odpovedi[level][scena][i])\r\n        else: \r\n            basic.show_string(i+1 + \".\" + odpovedi[level][scena][i])\r\n\r\ndef answerTime():\r\n    navigation = 0\r\n    while not(buttonPressed(confirmButton) and\r\n      odpovedi[level][scena][navigation - 1] != None):\r\n        \r\n        if navigation == 0:\r\n            displejTextu(0,None)\r\n        else:\r\n            displejOdpovedi(navigation - 1)\r\n      \r\n        basic.pause(200)\r\n        if buttonPressed(downButton) and navigation < 5:\r\n            navigation = navigation + 1\r\n        elif buttonPressed(upButton) and navigation > 0:\r\n            navigation = navigation - 1\r\n        \r\n\r\n    return navigation - 1\r\n\r\ndef confirmTime(txtNumero, txt):\r\n    while not buttonPressed(confirmButton):\r\n        displejTextu(txtNumero, txt)\r\n\r\n\r\n# Plany: \r\n#        funkce level executionn(celá logika jednoho levlu v jedné funkci) vrátí True pokud uspjeje hrac a False když ne\r\n#        level loop = while True loop, který se breakne pokud hrac uspjeje level\r\n#        více stránkové odpovědi = hledá kolik odpovědí se vejde do limitu(musim jeste zjistit = 1. MMMMMMMMMMMM  ) a podle toho rozprozstře odpovědi\r\n#                                                                                                M\r\n#                                                                                                                  