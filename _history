(buttons) ==  button:\r\n        return True\r\n    else:\r\n        return False\r\n\r\ndef displejTextu(txtNumero): #predelat na OLED\r\n    basic.clear_screen()\r\n    basic.show_string(texty[level][scena][txtNumero])\r\n\r\ndef displejOdpovedi(oznacenaOdpoved): #predelat na OLED\r\n    basic.clear_screen()\r\n    for i in range(4):\r\n        if odpovedi[level][scena][i] == None:\r\n            basic.show_string(\"-----------\")\r\n        elif i == oznacenaOdpoved:\r\n            basic.show_string(\"0.\" + odpovedi[level][scena][i])\r\n        else: \r\n            basic.show_string(i+1 + \".\" + odpovedi[level][scena][i])\r\n\r\ndef answerTime():\r\n    navigation = 0\r\n    while not(buttonIsPressed(confirmButton) and\r\n      odpovedi[level][scena][navigation - 1] != None):\r\n        \r\n        if navigation == 0:\r\n            displejTextu(0)\r\n        else:\r\n            displejOdpovedi(navigation - 1)\r\n      \r\n        basic.pause(200)\r\n        if buttonIsPressed(downButton) and navigation < 5:\r\n            navigation = navigation + 1\r\n        elif buttonIsPressed(upButton) and navigation > 0:\r\n            navigation = navigation - 1\r\n        \r\n\r\n    return navigation - 1","pxt.json":"{\n    \"name\": \"23C\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"tinkercademy-tinker-kit\": \"github:tinkertanker/pxt-tinkercademy-tinker-kit#v1.1.1\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}},{"timestamp":1774562599591,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"></block><block type=\"device_forever\" x=\"225\" y=\"20\"></block></xml>","main.ts":"","README.md":"","main.py":"level = 0\r\nsce